{
  "name": "vsce-git-tools",
  "displayName": "VSCE Git Tools",
  "publisher": "szczynk",
  "version": "0.0.1",
  "description": "VS Code extension for git-tools — commit message formatting and git helpers",
  "license": "MIT",
  "author": "szczynk",
  "repository": {
    "type": "https",
    "url": "https://github.com/szczynk/git-tools.git",
    "directory": "packages/vsce-git-tools"
  },
  "homepage": "https://github.com/szczynk/git-tools#readme",
  "bugs": {
    "url": "https://github.com/szczynk/git-tools/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "cp ../../README.md ./README.md && tsup",
    "clean": "rm -rf dist tsconfig.tsbuildinfo README.md *.vsix",
    "prepack": "npm run build",
    "lint": "tsc --noEmit",
    "package": "cp package.vscode.json package.json && vsce package && cp package.npm.json package.json"
  },
  "devDependencies": {
    "@szczynk/git-tools-core": "*",
    "@types/vscode": "^1.120.0",
    "tsup": "^8.5.1"
  },
  "icon": "llama.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelChatProvider:git-tools-llama"
  ],
  "contributes": {
    "configuration": {
      "title": "Git Tools LLM",
      "properties": {
        "git-tools.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8080/v1",
          "description": "Base URL for OpenAI-compatible API (llama.cpp, Ollama, etc.)"
        },
        "git-tools.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authenticated endpoints (optional)"
        },
        "git-tools.model": {
          "type": "string",
          "default": "",
          "description": "Model name (auto-detected from /models endpoint)"
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "git-tools-llama",
        "displayName": "Git Tools Local LLM"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-tools-llama",
          "title": "Git Tools LLM",
          "icon": "resources/llama-sidebar.svg"
        }
      ]
    },
    "views": {
      "git-tools-llama": [
        {
          "type": "webview",
          "id": "git-tools.llmConfig",
          "name": "LLM Configuration"
        }
      ]
    },
    "commands": [
      {
        "command": "git-tools.commit",
        "title": "Git Tools: AI Commit",
        "icon": "$(wand)"
      },
      {
        "command": "git-tools.status",
        "title": "Git Tools: Status"
      },
      {
        "command": "git-tools.restoreStaged",
        "title": "Git Tools: Restore Staged"
      },
      {
        "command": "git-tools.diff",
        "title": "Git Tools: Diff"
      },
      {
        "command": "git-tools.diffNoCompact",
        "title": "Git Tools: Diff (No Compact)"
      },
      {
        "command": "git-tools.formatMessage",
        "title": "Git Tools: Format Commit Message"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "git-tools.commit",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    },
    "languageModelTools": [
      {
        "name": "git_tools_git_status",
        "description": "Show compact git status (porcelain format with branch info). If staged changes are present, call git_tools_git_restore_staged to unstage them.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "cwd": { "type": "string", "description": "Current working directory" }
          }
        }
      },
      {
        "name": "git_tools_git_restore_staged",
        "description": "Unstage all staged changes.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "cwd": { "type": "string", "description": "Current working directory" }
          }
        }
      },
      {
        "name": "git_tools_git_diff",
        "description": "Show compact git diff with stat summary (500 line cap, 100 lines per hunk). If the result contains a hint, call git_tools_git_diff_no_compact.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "cwd": { "type": "string", "description": "Current working directory" },
            "args": { "type": "string", "description": "Extra arguments forwarded verbatim to git diff" }
          }
        }
      },
      {
        "name": "git_tools_git_diff_no_compact",
        "description": "Show full git diff with stat summary (no truncation).",
        "inputSchema": {
          "type": "object",
          "properties": {
            "cwd": { "type": "string", "description": "Current working directory" },
            "args": { "type": "string", "description": "Extra arguments forwarded verbatim to git diff" }
          }
        }
      },
      {
        "name": "git_tools_git_format_message",
        "description": "Assemble and validate a Conventional Commit message from structured fields. Call this after analyzing the diff.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": { "type": "string" },
                  "summary": { "type": "string" }
                },
                "required": ["path", "summary"]
              },
              "minItems": 1
            },
            "type": {
              "type": "string",
              "enum": ["feat", "fix", "refactor", "perf", "docs", "test", "chore", "build", "ci", "style", "revert"]
            },
            "summary": { "type": "string" },
            "scope": { "type": "string" },
            "body": { "type": "array", "items": { "type": "string" } },
            "breaking": { "type": "boolean" },
            "breaking_description": { "type": "string" }
          },
          "required": ["files", "type", "summary", "body"]
        }
      }
    ]
  },
  "extensionDependencies": [
    "vscode.git"
  ]
}
